# =============================================================================
# Dependencies
# =============================================================================
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# =============================================================================
# Environment files (only *.example variants are committed)
# =============================================================================
.env
.env.*
!.env.example
!.env.dev.example
!.env.prod.example
**/.env
**/.env.*
!**/.env.example
!**/.env.dev.example
!**/.env.prod.example

# =============================================================================
# Build outputs
# =============================================================================
dist/
build/
out/
**/dist/
**/build/
**/out/
*.tsbuildinfo
**/*.tsbuildinfo
.vite/
.next/
.nuxt/
.svelte-kit/
.cache/
.turbo/
.parcel-cache/

# =============================================================================
# User-uploaded handwriting samples (clinical PII; never commit)
# =============================================================================
server/src/uploads/*
!server/src/uploads/.gitkeep

# =============================================================================
# Test / coverage artifacts
# =============================================================================
coverage/
**/coverage/
.nyc_output/
*.lcov
junit.xml
test-results/

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# Editor / IDE
# =============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo
*.swp
.sublime-workspace
.sublime-project

# =============================================================================
# OS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Tooling caches
# =============================================================================
.npm/
.eslintcache
.stylelintcache
.prettiercache

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml
*.local.yml

# =============================================================================
# Temporary files
# =============================================================================
*.tmp
*.temp
*.bak
*.orig
.temp/
tmp/

# =============================================================================
# Secrets / credentials (defense in depth)
# =============================================================================
*.pem
*.key
*.crt
*.p12
*.pfx
*-keyfile.json
secrets/
credentials/

# =============================================================================
# Internal-only artifacts (audits, AI workspace, ad-hoc context)
