# Copy to server/.env.dev for docker-compose dev usage:
#   cp server/.env.dev.example server/.env.dev

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

MONGODB_URI=mongodb://host.docker.internal:27017/neuroassess

JWT_SECRET=replace-me-dev-only
JWT_REFRESH_SECRET=replace-me-dev-only
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="NeuroAssess Support <noreply@example.com>"

HUGGING_FACE_API_URL=
HUGGING_FACE_API_KEY=
